# Backend base URL the SPA calls.
# Local dev (backend in header mode → resolves to the seeded demo user):
VITE_API_URL=http://localhost:8000
# Deployed AWS API (jwt mode): no token needed to try the app — the SPA sends a
# generated X-Guest-Id and the user gets their own guest session (ADR-0009).
# Sign-in (Cognito) later migrates that guest data to a permanent account.
# VITE_API_URL=https://7x1e7unmh5.execute-api.us-east-1.amazonaws.com
